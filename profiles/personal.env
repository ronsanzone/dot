DOT_PROFILE_NAME="personal"

DOT_ITEMS=(
    dotfiles
    nvim
    claude_essentials
)

DOT_ITEM_dotfiles_LABEL="dotfiles"
DOT_ITEM_dotfiles_REPO="git@github.com:ronsanzone/dotfiles.git"
DOT_ITEM_dotfiles_PATH="$HOME/code/dotfiles"
DOT_ITEM_dotfiles_APPLY="./install.sh"

DOT_ITEM_nvim_LABEL="nvim"
DOT_ITEM_nvim_REPO="https://github.com/ronsanzone/kickstart.nvim.git"
DOT_ITEM_nvim_PATH="$HOME/.config/nvim"
DOT_ITEM_nvim_APPLY=""

DOT_ITEM_claude_essentials_LABEL="claude-essentials"
DOT_ITEM_claude_essentials_REPO="git@github.com:ronsanzone/claude-essentials.git"
DOT_ITEM_claude_essentials_PATH="$HOME/code/claude-essentials"
