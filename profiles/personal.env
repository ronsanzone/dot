DOT_PROFILE_NAME="personal"

# Apply order matters: public/shared agent assets first, then the private Pi
# overlay. Neither skills installer is allowed to write through a package link.
DOT_ITEMS=(
    dot
    dotfiles
    nvim
    agent_essentials
    pi_essentials
    context_engineering_workflows_v2
    mongo_pi_extensions
)

DOT_ITEM_dotfiles_LABEL="dotfiles"
DOT_ITEM_dotfiles_REPO="git@github.com:ronsanzone/dotfiles.git"
DOT_ITEM_dotfiles_PATH="$HOME/code/dotfiles"
DOT_ITEM_dotfiles_APPLY="./install.sh"

DOT_ITEM_nvim_LABEL="nvim"
DOT_ITEM_nvim_REPO="https://github.com/ronsanzone/kickstart.nvim.git"
DOT_ITEM_nvim_PATH="$HOME/.config/nvim"
DOT_ITEM_nvim_APPLY=""

DOT_ITEM_agent_essentials_LABEL="agent-essentials"
DOT_ITEM_agent_essentials_REPO="git@github.com:ronsanzone/agent-essentials.git"
DOT_ITEM_agent_essentials_PATH="$HOME/code/agent-essentials"
DOT_ITEM_agent_essentials_APPLY="./scripts/install-claude.sh"

DOT_ITEM_pi_essentials_LABEL="pi-essentials"
DOT_ITEM_pi_essentials_REPO="git@github.com:ronsanzone/pi-essentials.git"
DOT_ITEM_pi_essentials_PATH="$HOME/code/pi-essentials"
DOT_ITEM_pi_essentials_APPLY="./install.sh"

DOT_ITEM_context_engineering_workflows_v2_LABEL="context-engineering-workflows-v2"
DOT_ITEM_context_engineering_workflows_v2_REPO="git@github.com:ronsanzone/context-engineering-workflows-v2.git"
DOT_ITEM_context_engineering_workflows_v2_PATH="$HOME/code/context-engineering-workflows-v2"
DOT_ITEM_context_engineering_workflows_v2_APPLY="./install.sh"

DOT_ITEM_mongo_pi_extensions_LABEL="mongo-pi-extensions"
DOT_ITEM_mongo_pi_extensions_REPO="git@github.com:ronsanzone/mongo-pi-extensions.git"
DOT_ITEM_mongo_pi_extensions_PATH="$HOME/code/mongo-pi-extensions"
DOT_ITEM_mongo_pi_extensions_APPLY="./install.sh"

DOT_ITEM_dot_LABEL="dot"
DOT_ITEM_dot_REPO="git@github.com:ronsanzone/dot.git"
DOT_ITEM_dot_PATH="$HOME/code/dot"
DOT_ITEM_dot_APPLY="./install.sh"
